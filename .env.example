# === Obrigatórias / recomendadas (Peniel Mídia) ===
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=peniel-midia-super-secret-troque-em-producao

# === Servidor ===
PORT=3000
NODE_ENV=development
# Em produção use NODE_ENV=production (trust proxy no Express, etc.)

# Caminho absoluto ou relativo ao CWD do processo Node (recomendado em VPS / Docker)
# DB_PATH=/var/lib/peniel/peniel.db
# Front noutra origem (ex. Vite): ativa cabeçalhos CORS para esta URL
CORS_ORIGIN=http://localhost:5173

# === Primeira execução — admin seed ===
SEED_ADMIN_EMAIL=admin@peniel.com
SEED_ADMIN_SENHA=peniel123
SEED_ADMIN_NOME=Administrador

# Link nos e-mails de convite (use a URL pública real em produção)
APP_PUBLIC_URL=http://localhost:3000

# === E-mail (Gmail: use "palavra-passe de app", não a senha normal) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true ou 1 = TLS direto (porta 465). false = STARTTLS (587)
SMTP_SECURE=false
SMTP_USER=seu@gmail.com
SMTP_PASS=
SMTP_FROM="Peniel Mídia <seu@gmail.com>"

# === WhatsApp (comunicados — opcional) ===
# Provider usado neste projeto: whatsapp-web.js (sem custo por API)
WHATSAPP_PROVIDER=wwebjs
WWEBJS_SESSION_DIR=.wwebjs_auth
WWEBJS_CLIENT_ID=midia-escala-ai

# === Extras (ainda não usados pelo código deste repo) ===
# API_KEY=
# STORAGE_DIR=
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=1000
